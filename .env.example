# ─────────────────────────────────────────────────────────────────────────────
# AegisRAG — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in all values.
# NEVER commit .env.local to git.

# ─── SUPABASE ────────────────────────────────────────────────────────────────
# From: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── GOOGLE AI (GEMINI) ──────────────────────────────────────────────────────
# SDK to use: @google/genai (NOT @google/generative-ai)
# From: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
# Optional: second Gemini API key used as last-resort fallback when primary key is exhausted
GEMINI_API_KEY_2=your_second_gemini_api_key

# ─── COHERE RERANKER ─────────────────────────────────────────────────────────
# From: https://dashboard.cohere.com/api-keys
COHERE_API_KEY=your_cohere_api_key

# ─── RESEND (Email) ──────────────────────────────────────────────────────────
# From: https://resend.com/api-keys
RESEND_API_KEY=your_resend_api_key

# ─── APP CONFIG ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AegisRAG

# ─── FEATURE FLAGS ───────────────────────────────────────────────────────────
# Set to 'true' to enable; 'false' to disable
NEXT_PUBLIC_ENABLE_3D=false
NEXT_PUBLIC_DEMO_MODE=true

# ─── BGE EMBEDDING PROVIDER ──────────────────────────────────────────────────
# Set to 'bge' to use the local FastAPI sidecar embedding provider
EMBEDDING_PROVIDER=gemini
BGE_EMBEDDING_URL=http://localhost:8001/embed
BGE_MODEL_NAME=BAAI/bge-base-en-v1.5
BGE_BATCH_SIZE=64

# ─── RETRIEVAL CONFIG ────────────────────────────────────────────────────────
# Set to 'true' to resolve child chunks to parent page context
ENABLE_PARENT_CHILD_RETRIEVAL=false

